{
  "expo": {
    "name": "Qashy",
    "slug": "qashy",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "backgroundColor": "#F6F7F9",
    "scheme": "qashy",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#5966E9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "name": "Qashy",
      "shortName": "Qashy",
      "themeColor": "#5966E9",
      "backgroundColor": "#F7F7FB"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#5966E9",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 108,
          "dark": {
            "backgroundColor": "#0E0F13",
            "image": "./assets/images/splash-icon.png"
          }
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e7487171-c787-48dc-aea9-736d63f07042"
      }
    },
    "owner": "venusddev"
  }
}
